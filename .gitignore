# secrets — never commit
.env
.env.*
!.env.example
# ...but the scaffolding templates are not secrets — keep them tracked
!templates/env/.env.*
*.pem
*.key

# private seeds (your machine-specific configs live here, untracked)
seeds/private/
seeds/*.local.md

# os / editor
.DS_Store
*.bak

# local Claude Code / agent config — personal, never committed…
.claude/*
.agents/
# …except the committed autonomy hooks + their wiring (keep-going Stop hook & decide-yourself
# question gate), so working ON genesis dogfoods them. settings.local.json, skills/, and the
# transient hook-stop-ok marker stay personal/ignored.
!.claude/hooks/
!.claude/settings.json
!.claude/keep-going.on
!.claude/decide-yourself.on
.claude/hook-stop-ok

# local scratch
.scratch/*
!.scratch/README.md
