# .env.example — the ONLY env file that is committed. Variable NAMES only, never values.
# Copy to .env (git-ignored) and fill locally:  cp templates/env/.env.example .env
# Genesis appends the keys for each integration you choose (from integrations/registry/*.yaml).
# NOTHING here is a real secret. Real values live only in .env / .env.*, which are never committed or printed.
# For keys marked "# generate:", run the command and paste the output into your local .env — do NOT commit it.

# --- core ---
# the environment name the app runs in (development | production | test)
NODE_ENV=
# host:port (or full bind) the app listens on locally
APP_URL=
# server port
PORT=
# log verbosity (error | warn | info | debug)
LOG_LEVEL=

# --- app secrets (random — generate, never hand-pick) ---
# generate: openssl rand -hex 32      (alt: openssl rand -base64 32)
SESSION_SECRET=
# generate: openssl rand -hex 32      (alt: head -c 32 /dev/urandom | base64)
JWT_SECRET=
# generate: openssl rand -base64 32   (must be 32 bytes for AES-256)
ENCRYPTION_KEY=
# generate: openssl rand -base64 32   (Next.js / next-auth only — delete if not using)
NEXTAUTH_SECRET=

# --- datastore (names only; genesis fills the real driver at Phase 4) ---
# full connection string, e.g. postgres://user:pass@host:5432/db
DATABASE_URL=
# cache / queue connection, e.g. redis://localhost:6379
REDIS_URL=

# --- integrations (genesis appends only the keys for services you selected) ---
# each line below mirrors an integrations/registry/*.yaml env_keys list — names only.
# Stripe:         STRIPE_SECRET_KEY=  STRIPE_PUBLISHABLE_KEY=  STRIPE_WEBHOOK_SECRET=
# Supabase:       SUPABASE_URL=  SUPABASE_ANON_KEY=  SUPABASE_SERVICE_ROLE_KEY=
# Clerk:          CLERK_PUBLISHABLE_KEY=  CLERK_SECRET_KEY=
# Resend:         RESEND_API_KEY=
# Cloudflare R2:  R2_ACCOUNT_ID=  R2_ACCESS_KEY_ID=  R2_SECRET_ACCESS_KEY=  R2_BUCKET=
# Sentry:         SENTRY_DSN=  SENTRY_AUTH_TOKEN=
# Vercel:         VERCEL_TOKEN=
# Fly:            FLY_API_TOKEN=
# Render:         RENDER_API_KEY=

# --- media / AI providers (consumed by the media-gen skill; enable only if used) ---
# OpenAI:         OPENAI_API_KEY=
# Google:         GOOGLE_API_KEY=
